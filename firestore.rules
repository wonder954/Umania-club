rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // 共通関数
    // ============================================================
    function isLoggedIn() {
      return request.auth != null;
    }

    function isPostVisibleStrict(data, auth) {
      return
        data.visibility == "public"
        || (auth != null && data.authorId == auth.uid)
        || (
          auth != null
          && data.visibility.matches("^group:[A-Za-z0-9_-]+$")
          && exists(/databases/$(database)/documents/groups/$(data.visibility.split(":")[1]))
          && get(/databases/$(database)/documents/groups/$(data.visibility.split(":")[1])).data.members.hasAny([auth.uid])
        );
    }

    // ============================================================
    // races
    // ============================================================
    match /races/{raceId} {
      allow read: if true;
    }

    // ============================================================
    // posts（通常アクセス）
    // ============================================================
    match /races/{raceId}/posts/{postId} {

      // list（クエリ）はログイン済みならOK
      allow list: if request.auth != null;

      // get（単体取得）は厳密チェック
      allow get: if isPostVisibleStrict(resource.data, request.auth);

      // 作成（なりすまし防止）
      allow create: if isLoggedIn()
                    && request.resource.data.authorId == request.auth.uid;

      // 更新（投稿者本人のみ）
      allow update: if isLoggedIn()
                    && resource.data.authorId == request.auth.uid
                    && request.resource.data.likes is list
                    && request.resource.data.likes.size() <= 2000;

      // 削除（投稿者本人のみ）
      allow delete: if isLoggedIn()
                    && resource.data.authorId == request.auth.uid;

      // ------------------------------------------------------------
      // comments
      // ------------------------------------------------------------
      match /comments/{commentId} {

        // コメント一覧（list）は全許可
        allow list: if true;

        // コメント単体（get）は親投稿の可視性に従う
        allow get: if isPostVisibleStrict(
          get(/databases/$(database)/documents/races/$(raceId)/posts/$(postId)).data,
          request.auth
        );

        // 作成（なりすまし防止）
        allow create: if isLoggedIn()
                      && request.resource.data.authorId == request.auth.uid;

        // 更新（コメント作者のみ）
        allow update: if isLoggedIn()
                      && resource.data.authorId == request.auth.uid
                      && request.resource.data.likes is list
                      && request.resource.data.likes.size() <= 2000;

        // 削除（コメント作者のみ）
        allow delete: if isLoggedIn()
                      && resource.data.authorId == request.auth.uid;
      }
    }

    // ============================================================
    // groups
    // ============================================================
    match /groups/{groupId} {

      // 読み取りはログイン済みならOK
      allow read: if isLoggedIn();

      // 作成（create）は ownerId をチェック
      allow create: if isLoggedIn()
                    && request.resource.data.ownerId == request.auth.uid;

      // 更新（update）は既存データの ownerId をチェック
      allow update: if isLoggedIn()
                    && resource.data.ownerId == request.auth.uid;

      // 削除も同様
      allow delete: if isLoggedIn()
                    && resource.data.ownerId == request.auth.uid;
    }

    // ============================================================
    // users
    // ============================================================
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ============================================================
    // その他は拒否
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}