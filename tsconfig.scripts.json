{
    "compilerOptions": {
        "module": "es2020",
        "moduleResolution": "node",
        "target": "ES2020",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "noEmit": false,
        "outDir": "dist-scripts",
        "strict": true,
        "skipLibCheck": true
    },
    "include": [
        "scripts/**/*.ts",
        "utils/**/*.ts",
        "types/**/*.ts"
    ]
}